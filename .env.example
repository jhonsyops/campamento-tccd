# ====== .env.example ======
# Copia este archivo como ".env" y rellena los valores.
# El ".env" real NUNCA se sube a git (ponlo en .gitignore).

# --- Públicas (van al navegador; la anon key es pública por diseño) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_publica

# --- SECRETAS (solo en el servidor / Netlify Functions; NUNCA con prefijo VITE_) ---
# Estas jamás deben terminar en el bundle del front.
SUPABASE_SERVICE_ROLE=tu_service_role_key_secreta
WHATSAPP_TOKEN=token_secreto_de_tu_api_de_mensajeria
